# ============================================================
# Ettawa-Sense — Frontend / Monolith Environment Variables
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke Git.
# ============================================================

# ── Backend URL ──────────────────────────────────────────────
# Development:  http://localhost:3000 (monolith — same port)
# Production:   https://ettawa.yourdomain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# ── Mock Mode ────────────────────────────────────────────────
# true  = demo UI dengan data simulasi (tanpa ESP32, tanpa backend)
# false = data real dari ESP32 via MQTT (WAJIB false di production)
NEXT_PUBLIC_MOCK_MODE=false

# ── API Key ──────────────────────────────────────────────────
# Harus sama persis dengan API_KEY di server (backend/monolith).
# Generate key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEXT_PUBLIC_ prefix membuat nilai ini visible di browser — acceptable untuk
# internal dashboard, karena bukan credentials database/admin.
NEXT_PUBLIC_API_KEY=change-me-to-random-32-char-hex-string
