# ============================================================
# Ettawa-Sense — Production Environment Variables
#
# CARA PENGGUNAAN:
#   1. Salin file ini: cp .env.production.example .env
#   2. Isi semua nilai yang bertanda <GANTI_...>
#   3. JANGAN commit file .env ke Git — sudah ada di .gitignore
#
# File ini AMAN di-commit karena hanya berisi placeholder.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
# Port HARUS 5151 — sesuai nginx upstream di server:
#   upstream ettawa { server 127.0.0.1:5151; }
PORT=5151

# ── Frontend URL ─────────────────────────────────────────────
# URL publik domain production (tanpa trailing slash)
NEXT_PUBLIC_BACKEND_URL=https://ettawa-sakra.momoi.my.id

# ── Mock Mode ────────────────────────────────────────────────
# WAJIB false di production — data real dari ESP32 via MQTT
# true hanya untuk demo UI tanpa hardware
NEXT_PUBLIC_MOCK_MODE=false

# Jalankan mock generator server-side?
# false di production — generator aktif hanya saat ESP32 belum terhubung
USE_MOCK_DATA=false

# ── API Key ──────────────────────────────────────────────────
# Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEDUA nilai di bawah HARUS SAMA persis
API_KEY=<GANTI_DENGAN_RANDOM_64_CHAR_HEX>
NEXT_PUBLIC_API_KEY=<GANTI_DENGAN_RANDOM_64_CHAR_HEX>

# ── MQTT Credentials (Aedes Broker + ESP32) ──────────────────
# HARUS IDENTIK dengan MQTT_USERNAME & MQTT_PASSWORD di config.h ESP32
MQTT_USERNAME=<GANTI_DENGAN_USERNAME_MQTT>
MQTT_PASSWORD=<GANTI_DENGAN_PASSWORD_MQTT>

# ── Internal MQTT Broker URL ─────────────────────────────────
# URL yang digunakan server.js untuk connect ke Aedes embedded broker.
# Tetap loopback — tidak perlu diubah di Docker (container network internal)
MQTT_BROKER_URL=ws://127.0.0.1:5151/mqtt

# ── CORS ─────────────────────────────────────────────────────
# Pisahkan beberapa origin dengan koma (tanpa spasi)
ALLOWED_ORIGINS=https://ettawa-sakra.momoi.my.id

# ── InfluxDB (Opsional) ──────────────────────────────────────
# Jika tidak diisi, sistem otomatis pakai ring-buffer in-memory (500 data point).
# Data in-memory hilang saat container restart — InfluxDB untuk persistent storage.
# INFLUX_URL=http://localhost:8086
# INFLUX_TOKEN=<GANTI_DENGAN_INFLUXDB_TOKEN>
# INFLUX_ORG=capratech
# INFLUX_BUCKET=ettawa
